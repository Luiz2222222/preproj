# ============================================
# Copie este arquivo para .env e preencha
# ============================================

# --- Django ---
# Gere uma chave segura em: https://djecrety.ir/
SECRET_KEY=coloque-uma-chave-secreta-aqui
ALLOWED_HOSTS=seudominio.com,www.seudominio.com

# --- Banco de Dados (PostgreSQL) ---
DB_NAME=portal_tcc
DB_USER=portal_tcc
DB_PASSWORD=coloque-uma-senha-forte-aqui

# --- CORS / CSRF (dominio do seu site, com https) ---
CORS_ALLOWED_ORIGINS=https://seudominio.com
CSRF_TRUSTED_ORIGINS=https://seudominio.com

# --- Porta publica (Coolify gerencia isso, pode deixar 80) ---
PORT=80

# --- E-mail (opcional) ---
EMAIL_ENABLED=false
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Para ativar e-mail real:
# EMAIL_ENABLED=true
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=seu_email@gmail.com
# EMAIL_HOST_PASSWORD=senha_de_app_do_gmail
# DEFAULT_FROM_EMAIL=Portal TCC <seu_email@gmail.com>
